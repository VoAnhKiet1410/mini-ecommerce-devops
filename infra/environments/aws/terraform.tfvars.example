aws_region              = "ap-southeast-1"
project_name            = "mini-ecommerce-devops"
github_org              = "VoAnhKiet1410"
github_repo             = "mini-ecommerce-devops"
rds_skip_final_snapshot   = true
create_github_oidc_provider = true

# Optional: restrict EKS public API to your IP (recommended for demos)
# cluster_endpoint_public_access_cidrs = ["203.0.113.10/32"]

# EKS worker (default: m7i-flex.large — more pod headroom than t3.small)
# eks_instance_types = ["m7i-flex.large"]

# Must match infra/bootstrap/state lock_table_name and backend.hcl dynamodb_table
# terraform_state_lock_table_name = "mini-ecommerce-devops-tflock"

# CI (terraform-plan.yml) sets TF_VAR_github_org/repo from GitHub context — keep values here aligned for local apply.
